<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Enable debugging on device; must match signing profile -->
	<key>get-task-allow</key>
	<true/>
	<!-- Required for iOS 15+ Developer Mode to allow JIT -->
	<key>com.apple.developer.kernel.extended-virtual-addressing</key>
	<true/>
	<!-- Allow JIT memory on device (for development). Actual entitlement name may vary by iOS version; developer mode is required. -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
</dict>
</plist>